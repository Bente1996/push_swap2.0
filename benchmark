#!/usr/bin/env bash

fatal() {
	echo "[FATAL]" $@
	exit 1
}

info() {
	echo "[INFO]" $@
}

error() {
	echo "[ERROR]" $@
}

main() {
	local sample_size=${3}
	local test_size=${1}
	local max_op=${2}
	sample_size=${sample_size:=100}
	local fails=0
	for i in `seq ${sample_size}`; do
		./test_ps.sh ${test_size} ${max_op} \
			| grep "ERROR" >/dev/null 2>/dev/null \
			&& fails=$(( $fails + 1 )) \
			&& info "${i}th iteration failed"
	done ;
	info "${fails} out of ${sample_size} failed to stay under the max op count"
	info "$(( ( ${fails} * 100 ) / ( ${sample_size} ) ))% failed"
}

main $@
